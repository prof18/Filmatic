<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.discover.DiscoverFragment">

    <androidx.appcompat.widget.Toolbar
            android:id="@+id/EXPLORE_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_bkg"
            android:contentInsetStart="@dimen/card_margin"
            android:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:contentInsetStart="@dimen/card_margin"
            app:layout_constraintBottom_toTopOf="@id/EXPLORE_popular_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:title="@string/app_name" />

    <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/EXPLORE_animation"
            android:layout_width="150dp"
            android:layout_height="150dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <TextView
            android:id="@+id/EXPLORE_popular_title"
            style="@style/TextAppearance.Filmatic.Headline5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_small"
            android:layout_marginTop="@dimen/margin_small"
            android:text="@string/EXPLORE_popular_title"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/EXPLORE_popular_list"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/EXPLORE_toolbar"
            tools:visibility="visible"

            />

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/EXPLORE_popular_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toTopOf="@id/EXPLORE_next_movie_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/EXPLORE_popular_title"
            tools:listitem="@layout/item_movie_bottom_title" />


    <TextView
            android:id="@+id/EXPLORE_next_movie_title"
            style="@style/TextAppearance.Filmatic.Headline5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_small"
            android:layout_marginTop="@dimen/margin_small"
            android:text="@string/EXPLORE_next_movie_title"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/EXPLORE_next_movie_tile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/EXPLORE_popular_list"
            tools:visibility="visible"

            />


    <include
            android:id="@+id/EXPLORE_next_movie_tile"
            layout="@layout/item_movie_big"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/card_margin"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/EXPLORE_next_movie_title"
            tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>