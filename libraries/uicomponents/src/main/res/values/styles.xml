<resources>

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight">

        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorOnBackground">@color/colorOnBackground</item>
        <item name="android:statusBarColor">@color/statusBarColor</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Global shape attributes -->
        <item name="shapeAppearanceSmallComponent">@style/AppShapeAppearance.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/AppShapeAppearance.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/AppShapeAppearance.LargeComponent</item>

        <item name="textAppearanceHeadline1">@style/TextAppearance.Filmatic.Headline1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.Filmatic.Headline2</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.Filmatic.Headline3</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.Filmatic.Headline4</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.Filmatic.Headline5</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.Filmatic.Headline6</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.Filmatic.Subtitle1</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.MaterialComponents.Subtitle2
        </item>
        <item name="textAppearanceBody1">@style/TextAppearance.Filmatic.Body1</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Filmatic.Body2</item>
        <item name="textAppearanceCaption">@style/TextAppearance.Filmatic.Caption</item>

        <!-- TODO: customize it? -->
        <item name="textAppearanceButton">@style/TextAppearance.MaterialComponents.Button</item>
        <item name="textAppearanceOverline">@style/TextAppearance.MaterialComponents.Overline</item>

        <item name="bottomAppBarStyle">@style/AppBottomNavigation</item>

    </style>


    <style name="AppTextAppearance.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="AppShapeAppearance.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">@dimen/card_corner_radius</item>
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="AppShapeAppearance.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/card_corner_radius</item>
    </style>

    <style name="AppShapeAppearance.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/card_corner_radius</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>


    <!--  Check the font style  -->

    <style name="TextAppearance.Filmatic.Headline1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="fontFamily">@font/opensans_bold</item>
    </style>

    <style name="TextAppearance.Filmatic.Headline2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="fontFamily">@font/opensans_bold</item>
    </style>

    <style name="TextAppearance.Filmatic.Headline3" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="fontFamily">@font/opensans_bold</item>
    </style>

    <style name="TextAppearance.Filmatic.Headline4" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="fontFamily">@font/opensans_bold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.005625</item>
    </style>

    <style name="TextAppearance.Filmatic.Headline5" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="fontFamily">@font/opensans_semibold</item>
    </style>

    <style name="TextAppearance.Filmatic.Headline6" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="fontFamily">@font/opensans_semibold</item>
    </style>

    <style name="TextAppearance.Filmatic.Subtitle1" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="fontFamily">@font/opensans_light</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Filmatic.SearchHint" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="fontFamily">@font/opensans_light</item>
    </style>

    <style name="TextAppearance.Filmatic.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="fontFamily">@font/opensans_regular</item>
    </style>

    <style name="TextAppearance.Filmatic.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="fontFamily">@font/opensans_regular</item>
    </style>

    <style name="TextAppearance.Filmatic.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">@font/opensans_light</item>
    </style>

    <style name="TextAppearance.Filmatic.Genre" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="fontFamily">@font/opensans_bold</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SearchViewTheme" parent="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="colorControlActivated">?android:colorAccent</item>
        <item name="android:searchViewStyle">@style/Widget.Filmatic.SearchView</item>
    </style>

    <style name="Widget.Filmatic.SearchView" parent="android:style/Widget.Material.SearchView">
        <item name="android:searchIcon">@android:color/transparent</item>
        <item name="android:searchHintIcon">@android:color/transparent</item>
        <item name="queryBackground">@color/grey</item>
        <item name="android:submitBackground">@android:color/transparent</item>
    </style>

    <!-- Using AppBottomNavigation2 to avoid conflicts with the main playground style -->
    <style name="AppBottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="backgroundTint">@color/statusBarColor</item>
        <item name="itemIconTint">@color/bottom_navigation_item_color</item>
        <item name="itemTextColor">@color/bottom_navigation_item_color</item>
        <item name="itemRippleColor">@color/bottom_navigation_item_ripple_color</item>
        <item name="itemTextAppearanceActive">?attr/textAppearanceCaption</item>
        <item name="itemTextAppearanceInactive">?attr/textAppearanceCaption</item>
    </style>

</resources>
